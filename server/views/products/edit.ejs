<% layout('layouts/boilerplate') %>

<%- include('../partials/navbar') %>   
<%- include('../partials/flash') %>  

<div class="container mt-5">
  <div class="row justify-content-center">

    <div class="col-lg-6">
      <div class="card shadow-lg border-0 rounded-4 p-4">

        <h3 class="mb-4 text-center">Edit Product</h3>

        <!-- here we use method override to update and use this /products/<%= foundProduct._id %>?_method=PATCH  -->
        <form action="/products/<%= foundProduct._id %>?_method=PATCH" method="POST"> 

          <!-- Name -->
          <div class="mb-3">
            <label for="naam" class="form-label">Product Name</label>
            <input 
              type="text" 
              class="form-control" 
              name="name" 
              id="naam" 
              placeholder="Enter product name"
              value="<%= foundProduct.name %>" 
              <!-- value to get the previos value -->
              required
            >
          </div>

          <!-- Image -->
          <div class="mb-3">
            <label for="img" class="form-label">Image URL</label>
            <input 
              type="text" 
              class="form-control" 
              name="img" 
              id="img" 
              placeholder="Enter image URL"
              value="<%= foundProduct.img %>"
            >
          </div>

          <!-- Price -->
          <div class="mb-3">
            <label for="paisa" class="form-label">Price (₹)</label>
            <input 
              type="number" 
              class="form-control" 
              name="price" 
              id="paisa" 
              placeholder="Enter price"
              value="<%= foundProduct.price %>"
              required
            >
          </div>

          <!-- Description -->
          <div class="mb-3">
            <label for="desc" class="form-label">Description</label>
            <textarea 
              class="form-control" 
              name="desc" 
              id="desc" 
              rows="4" 
              placeholder="Enter product description"
            ><%= foundProduct.desc %></textarea>
          </div>

          <!-- Buttons -->
          <div class="d-flex justify-content-between">
            <a href="/products/<%= foundProduct._id %>" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button class="btn btn-success btn-sm px-4" type="submit">Update</button>
          </div>

        </form>

      </div>
    </div>

  </div>
</div>