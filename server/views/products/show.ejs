<% layout('layouts/boilerplate') %>

  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %> 

    <div class="container mt-4">
      <div class="row justify-content-center">

        <!-- Product Card -->
        <div class="col-lg-5 mb-4">
          <div class="card shadow-lg border-0 rounded-4">
            <img src="<%= foundProduct.img %>" class="card-img-top rounded-top-4"
              style="height:300px; object-fit:cover;" alt="product">

            <div class="card-body">
              <h3 class="card-title fw-bold">
                <%= foundProduct.name %>
              </h3>
              <h5 class="text-success mb-2">₹ <%= foundProduct.price %>
              </h5>
              <p class="text-muted">
                <%= foundProduct.desc %>
              </p>

              <div class="d-flex gap-2">
                <a href="/products/<%= foundProduct._id %>/edit" class="btn btn-outline-dark btn-sm">Edit</a>
                <a href="#" class="btn btn-outline-secondary btn-sm">Add to Cart</a>
                <a href="#" class="btn btn-success btn-sm">Buy Now</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Review Section -->
        <div class="col-lg-5">

          <h3 class="mb-3">Leave a Review</h3>

          <form action="/products/<%= foundProduct._id %>/review" method="POST" class="mb-4">

            <fieldset class="starability-basic mb-3">
              <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked />
              <input type="radio" id="first-rate1" name="rating" value="1" />
              <label for="first-rate1">1</label>
              <input type="radio" id="first-rate2" name="rating" value="2" />
              <label for="first-rate2">2</label>
              <input type="radio" id="first-rate3" name="rating" value="3" />
              <label for="first-rate3">3</label>
              <input type="radio" id="first-rate4" name="rating" value="4" />
              <label for="first-rate4">4</label>
              <input type="radio" id="first-rate5" name="rating" value="5" />
              <label for="first-rate5">5</label>
            </fieldset>

            <div class="mb-3">
              <label class="form-label">Comment</label>
              <textarea class="form-control" rows="3" name="comment"></textarea>
            </div>

            <button class="btn btn-success btn-sm">Submit Review</button>
          </form>

          <!-- Reviews List -->
          <h5 class="mb-3">Customer Reviews</h5>

          <% for(let review of foundProduct.reviews){ %>

            <div class="card mb-3 shadow-sm border-0 rounded-3">
              <div class="card-body">

                <div class="d-flex justify-content-between">
                  <p class="text-muted">
                    <% if(review.createdAt){ %>
                      <%= review.createdAt.toDateString() %>
                        <% } %>
                    </p>
                    
                  <span class="badge bg-warning text-dark">
                    <%= review.rating %>/5
                  </span>
                </div>

                <p class="mt-2 mb-2">
                  <%= review.comment %>
                </p>

              </div>
            </div>
            <% } %>

        </div>

      </div>
    </div>